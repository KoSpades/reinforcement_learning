# Use this mode for Google AI Studio keys. These usually start with AIza.
LLM_PROVIDER=ai_studio
GEMINI_API_KEY=your_google_ai_studio_api_key_here

# Use this mode instead if your credential starts with AQ. and came from Google Cloud/Vertex.
# LLM_PROVIDER=vertex
# VERTEX_ACCESS_TOKEN=your_google_cloud_access_token_here
# VERTEX_PROJECT_ID=your_google_cloud_project_id_here
# VERTEX_LOCATION=global

GROQ_API_KEY=your_groq_api_key_here
